<turbo-frame id="player_modal_frame">
  <div
    data-player-modal-root
    data-player-modal-name="<%= @player.name %>"
    data-player-modal-player-id="<%= @player.id %>"
    data-player-modal-team-id="<%= @team.id %>"
  >
    <%= render "players/modal/header_bar",
      player: @player,
      team: @team,
      seasons: @seasons,
      selected_season: @selected_season,
      next_game: @next_game,
      opponent_team: @opponent_team,
      defense_vs_position: @defense_vs_position,
      next_game_projection: @next_game_projection,
      proj_by_player_id: @proj_by_player_id,
      proj_dist_by_player_id: @proj_dist_by_player_id
    %>

    <div class="px-1">
      <%= render "players/modal/tabs" %>
    </div>

    <div class="tab-content px-1">
      <%# OVERVIEW %>
      <div class="tab-pane fade show active" id="player-pane-overview" role="tabpanel">
        <%= render "players/modal/panes/overview",
          player: @player,
          team: @team,
          last_five_games: @last_five_games,
          last_ten_games: @last_ten_games,
          all_games: @game_logs,
          last_five_averages: @last_five_averages,
          current_season: @selected_season,
          player_stats: @player_stats,
          next_game_projection: @next_game_projection,
          betting_info: @betting_info,
          proj_by_player_id: @proj_by_player_id,
          proj_dist_by_player_id: @proj_dist_by_player_id
        %>
      </div>

      <%# GAME LOGS (full season) %>
      <div class="tab-pane fade" id="player-pane-gamelog" role="tabpanel">
        <%= render "players/modal/panes/game_logs",
              player: @player,
              team: @team,
              game_logs: @game_logs %>
      </div>

    </div>
  </div>
</turbo-frame>