<script>
  function initTooltips() {
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
      if (bootstrap.Tooltip.getInstance(el)) return;

      const tip = new bootstrap.Tooltip(el);

      el.addEventListener("shown.bs.tooltip", function () {
        const inst = bootstrap.Tooltip.getInstance(el);
        if (!inst) return;

        if (el._tooltipTimeout) clearTimeout(el._tooltipTimeout);
        el._tooltipTimeout = setTimeout(function () {
          inst.hide();
        }, 5000);
      });
    });
  }

  function applyStickyColumn(tableSelector, backgroundColor) {
    const $table = $(tableSelector);
    if ($table.length === 0) return;

    $table.find("thead .sticky-col").css({
      position: "sticky",
      left: "0",
      backgroundColor: backgroundColor,
      zIndex: 3,
      borderRight: "1px solid #ddd"
    });

    $table.find("tbody .sticky-col").css({
      position: "sticky",
      left: "0",
      backgroundColor: backgroundColor,
      zIndex: 2,
      borderRight: "1px solid #ddd"
    });
  }

  function initQuickGuideMetricsChart() {
    const canvas = document.getElementById("quickGuideMetricsChart");
    if (!canvas) return;

    if (canvas._chartInstance) {
      canvas._chartInstance.destroy();
    }

    const labels = <%= raw quick_guide_chart_labels.to_json %>;
    const maeData = <%= raw quick_guide_chart_mae.to_json %>;
    const biasData = <%= raw quick_guide_chart_bias.to_json %>;

    canvas._chartInstance = new Chart(canvas, {
      type: "bar",
      data: {
        labels: labels,
        datasets: [
          {
            label: "MAE",
            data: maeData
          },
          {
            label: "Bias",
            data: biasData
          }
        ]
      },
      options: {
        indexAxis: "y",
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          x: {
            beginAtZero: false,
            ticks: {
              precision: 0
            }
          },
          y: {
            ticks: {
              autoSkip: false
            }
          }
        },
        plugins: {
          legend: {
            display: true,
            position: "top"
          },
          tooltip: {
            callbacks: {
              label: function(context) {
                return `${context.dataset.label}: ${context.raw}`;
              }
            }
          }
        }
      }
    });
