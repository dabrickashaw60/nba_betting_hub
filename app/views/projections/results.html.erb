              { x: 0, y: 0 },
              { x: 45, y: 45 }
            ],
            type: "line",
            pointRadius: 0,
            borderWidth: 2
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          x: {
            title: {
              display: true,
              text: "Projected Minutes"
            }
          },
          y: {
            title: {
              display: true,
              text: "Actual Minutes"
            }
          }
        },
        plugins: {
          legend: {
            display: true,
            position: "top"
          }
        }
      }
    });
  }

  document.addEventListener("turbo:load", function () {
    applyStickyColumn("#away-box-score-table", "white");
    applyStickyColumn("#home-box-score-table", "white");
    initTooltips();
    initQuickGuideMetricsChart();
    initAwayMetricsChart();
    initHomeMetricsChart();
    initAwayMinutesRangeChart();
    initAwayMinutesCalibrationChart();
    initHomeMinutesRangeChart();
    initHomeMinutesCalibrationChart();    
  });

  document.addEventListener("turbo:before-cache", function () {
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
      const tip = bootstrap.Tooltip.getInstance(el);
      if (tip) tip.dispose();
      if (el._tooltipTimeout) clearTimeout(el._tooltipTimeout);
      el._tooltipTimeout = null;
    });

    const quickGuideCanvas = document.getElementById("quickGuideMetricsChart");
    if (quickGuideCanvas && quickGuideCanvas._chartInstance) {
      quickGuideCanvas._chartInstance.destroy();
      quickGuideCanvas._chartInstance = null;
    }

    const awayCanvas = document.getElementById("awayMetricsChart");
    if (awayCanvas && awayCanvas._chartInstance) {
      awayCanvas._chartInstance.destroy();
      awayCanvas._chartInstance = null;
    }

    const homeCanvas = document.getElementById("homeMetricsChart");
    if (homeCanvas && homeCanvas._chartInstance) {
      homeCanvas._chartInstance.destroy();
      homeCanvas._chartInstance = null;
    }

    const awayMinutesRangeCanvas = document.getElementById("awayMinutesRangeChart");
    if (awayMinutesRangeCanvas && awayMinutesRangeCanvas._chartInstance) {
      awayMinutesRangeCanvas._chartInstance.destroy();
      awayMinutesRangeCanvas._chartInstance = null;
    }

    const awayMinutesCalibrationCanvas = document.getElementById("awayMinutesCalibrationChart");
    if (awayMinutesCalibrationCanvas && awayMinutesCalibrationCanvas._chartInstance) {
      awayMinutesCalibrationCanvas._chartInstance.destroy();
      awayMinutesCalibrationCanvas._chartInstance = null;
    }

    const homeMinutesRangeCanvas = document.getElementById("homeMinutesRangeChart");
    if (homeMinutesRangeCanvas && homeMinutesRangeCanvas._chartInstance) {
      homeMinutesRangeCanvas._chartInstance.destroy();
      homeMinutesRangeCanvas._chartInstance = null;
    }

    const homeMinutesCalibrationCanvas = document.getElementById("homeMinutesCalibrationChart");
    if (homeMinutesCalibrationCanvas && homeMinutesCalibrationCanvas._chartInstance) {
      homeMinutesCalibrationCanvas._chartInstance.destroy();
      homeMinutesCalibrationCanvas._chartInstance = null;
    }

  });
</script>
