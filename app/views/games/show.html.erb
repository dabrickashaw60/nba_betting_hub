<h1 class="mb-4 text-center">Game Details for <%= @game.date.strftime("%B %d, %Y") %></h1>

<div class="container">
  <% if @game.date < Date.today %>
    <!-- Box Score Section (for past games) -->
      <%= button_to "Update Box Score", scrape_box_score_game_path(@game), method: :post, class: "btn btn-primary mb-4" %>

    <div class="card mb-4">
      <div class="card-header">
        <h3>Box Score</h3>
      </div>
      <div class="card-body">
        <div class="row">
          <!-- Visitor Team Box Score -->
          <div class="col-md-6">
            <h4><%= @game.visitor_team.name %> Box Score</h4>
            <table class="table table-striped">
              <thead>
                <tr>
                  <th>Player</th>
                  <th>MP</th>
                  <th>FG</th>
                  <th>FGA</th>
                  <th>FG%</th>
                  <th>3P</th>
                  <th>3PA</th>
                  <th>3P%</th>
                  <th>FT</th>
                  <th>FTA</th>
                  <th>FT%</th>
                  <th>ORB</th>
                  <th>DRB</th>
                  <th>TRB</th>
                  <th>AST</th>
                  <th>STL</th>
                  <th>BLK</th>
                  <th>TO</th>
                  <th>PF</th>
                  <th>PTS</th>
                  <th>GmSc</th>
                  <th>+/-</th>
                </tr>
              </thead>
              <tbody>
                <% @game.box_scores.where(team: @game.visitor_team).each do |box_score| %>
                  <tr>
                    <td><%= box_score.player.name %></td>
                    <td><%= box_score.minutes_played %></td>
                    <td><%= box_score.field_goals %></td>
                    <td><%= box_score.field_goals_attempted %></td>
                    <td><%= box_score.field_goal_percentage %></td>
                    <td><%= box_score.three_point_field_goals %></td>
                    <td><%= box_score.three_point_field_goals_attempted %></td>
                    <td><%= box_score.three_point_percentage %></td>
                    <td><%= box_score.free_throws %></td>
                    <td><%= box_score.free_throws_attempted %></td>
                    <td><%= box_score.free_throw_percentage %></td>
                    <td><%= box_score.offensive_rebounds %></td>
                    <td><%= box_score.defensive_rebounds %></td>
                    <td><%= box_score.total_rebounds %></td>
                    <td><%= box_score.assists %></td>
                    <td><%= box_score.steals %></td>
                    <td><%= box_score.blocks %></td>
                    <td><%= box_score.turnovers %></td>
                    <td><%= box_score.personal_fouls %></td>
                    <td><%= box_score.points %></td>
                    <td><%= box_score.game_score %></td>
                    <td><%= box_score.plus_minus %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <!-- Home Team Box Score -->
          <div class="col-md-6">
            <h4><%= @game.home_team.name %> Box Score</h4>
            <table class="table table-striped">
              <thead>
                <tr>
                  <th>Player</th>
                  <th>MP</th>
                  <th>FG</th>
                  <th>FGA</th>
                  <th>FG%</th>
                  <th>3P</th>
                  <th>3PA</th>
                  <th>3P%</th>
                  <th>FT</th>
                  <th>FTA</th>
                  <th>FT%</th>
                  <th>ORB</th>
                  <th>DRB</th>
                  <th>TRB</th>
                  <th>AST</th>
                  <th>STL</th>
                  <th>BLK</th>
                  <th>TO</th>
                  <th>PF</th>
                  <th>PTS</th>
                  <th>GmSc</th>
                  <th>+/-</th>
                </tr>
              </thead>
              <tbody>
                <% @game.box_scores.where(team: @game.home_team).each do |box_score| %>
                  <tr>
                    <td><%= box_score.player.name %></td>
                    <td><%= box_score.minutes_played %></td>
                    <td><%= box_score.field_goals %></td>
                    <td><%= box_score.field_goals_attempted %></td>
                    <td><%= box_score.field_goal_percentage %></td>
                    <td><%= box_score.three_point_field_goals %></td>
                    <td><%= box_score.three_point_field_goals_attempted %></td>
                    <td><%= box_score.three_point_percentage %></td>
                    <td><%= box_score.free_throws %></td>
                    <td><%= box_score.free_throws_attempted %></td>
                    <td><%= box_score.free_throw_percentage %></td>
                    <td><%= box_score.offensive_rebounds %></td>
                    <td><%= box_score.defensive_rebounds %></td>
                    <td><%= box_score.total_rebounds %></td>
                    <td><%= box_score.assists %></td>
                    <td><%= box_score.steals %></td>
                    <td><%= box_score.blocks %></td>
                    <td><%= box_score.turnovers %></td>
                    <td><%= box_score.personal_fouls %></td>
                    <td><%= box_score.points %></td>
                    <td><%= box_score.game_score %></td>
                    <td><%= box_score.plus_minus %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Game Details Section -->
  <div class="row">
    <!-- Visitor Team Card -->
    <div class="col-md-6">
      <div class="card mb-4">
        <div class="card-header">
          <h3><%= @visitor_team.name %> (Visitor)</h3>
        </div>
        <div class="card-body">
          <p><strong>Points:</strong> <%= @game.visitor_points %></p>
          <p><strong>Location:</strong> <%= @game.location %></p>
          <p><strong>Time:</strong> <%= @game.time.strftime("%I:%M %p") %></p>

          <h4>Player Stats</h4>
          <table class="table table-striped">
            <thead>
              <tr>
                <th>Player</th>
                <th>Points</th>
                <th>Rebounds</th>
                <th>Assists</th>
              </tr>
            </thead>
            <tbody>
              <% @visitor_team_players.each do |player| %>
                <tr>
                  <td><%= player.name %></td>
                  <td><%= player.player_stat&.points || "N/A" %></td>
                  <td><%= player.player_stat&.total_rebounds || "N/A" %></td>
                  <td><%= player.player_stat&.assists || "N/A" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Home Team Card -->
    <div class="col-md-6">
      <div class="card mb-4">
        <div class="card-header">
          <h3><%= @home_team.name %> (Home)</h3>
        </div>
        <div class="card-body">
          <p><strong>Points:</strong> <%= @game.home_points %></p>
          <p><strong>Location:</strong> <%= @game.location %></p>
          <p><strong>Time:</strong> <%= @game.time.strftime("%I:%M %p") %></p>

          <h4>Player Stats</h4>
          <table class="table table-striped">
            <thead>
              <tr>
                <th>Player</th>
                <th>Points</th>
                <th>Rebounds</th>
                <th>Assists</th>
              </tr>
            </thead>
            <tbody>
              <% @home_team_players.each do |player| %>
                <tr>
                  <td><%= player.name %></td>
                  <td><%= player.player_stat&.points || "N/A" %></td>
                  <td><%= player.player_stat&.total_rebounds || "N/A" %></td>
                  <td><%= player.player_stat&.assists || "N/A" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
