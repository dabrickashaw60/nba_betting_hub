<table class="table table-hover preview-table">
  <thead>
    <tr>
      <th class="sticky-col">Player</th>
      <th>MP</th>
      <th>USG%</th>
      <th>PTS</th>
      <th>REB</th>
      <th>REB%</th>
      <th>AST</th>
      <th>AST%</th>
      <th>3PM</th>
      <th>P+A</th>
      <th>P+R</th>
      <th>R+A</th>
      <th>P+R+A</th>
    </tr>
  </thead>

  <tbody>
    <% players.each do |data| %>
      <% p    = data[:player] %>
      <% proj = data[:projection] %>
      <% dist = data[:distribution] %>

      <% mp =
           if dist&.minutes_mean.present?
             dist.minutes_mean.to_f
           else
             proj&.expected_minutes.to_f
           end
      %>

      <% usg =
           proj&.usage_pct
      %>

      <% rebp =
           proj&.rebound_pct
      %>

      <% astp =
           proj&.assist_pct
      %>

      <% pts =
           dist&.points_mean.present? ? dist.points_mean.to_f : proj&.proj_points.to_f
      %>

      <% reb =
           dist&.rebounds_mean.present? ? dist.rebounds_mean.to_f : proj&.proj_rebounds.to_f
      %>

      <% ast =
           dist&.assists_mean.present? ? dist.assists_mean.to_f : proj&.proj_assists.to_f
      %>

      <% thr =
           dist&.threes_mean.present? ? dist.threes_mean.to_f : proj&.proj_threes.to_f
      %>

      <tr>
        <td class="sticky-col">
          <%= link_to "#",
                class: "player-modal-link text-decoration-none",
                data: {
                  player_url: team_player_path(p.team, p),
                  bs_toggle: "modal",
                  bs_target: "#playerModal"
                } do %>
            <img src="<%= p.profile_picture_url %>" width="20" class="rounded-circle me-2">
            <%= p.short_name %>
          <% end %>
        </td>

        <td><%= mp.to_f.round(1) %></td>

        <td>
          <%= usg.present? ? "#{usg.to_f.round(1)}%" : "—" %>
        </td>

        <td><%= pts.to_f.round(1) %></td>
        <td><%= reb.to_f.round(1) %></td>
        <td><%= rebp.present? ? "#{rebp.to_f.round(1)}%" : "—" %></td>

        <td><%= ast.to_f.round(1) %></td>
        <td><%= astp.present? ? "#{astp.to_f.round(1)}%" : "—" %></td>

        <td><%= thr.to_f.round(1) %></td>

        <td><%= (pts.to_f + ast.to_f).round(1) %></td>
        <td><%= (pts.to_f + reb.to_f).round(1) %></td>
        <td><%= (reb.to_f + ast.to_f).round(1) %></td>
        <td><%= (pts.to_f + reb.to_f + ast.to_f).round(1) %></td>
      </tr>
    <% end %>
  </tbody>
</table>